{
  "name": "@kaosc/@kaosc/react-native-draggable-flatlist",
  "version": "4.0.6",
  "description": "A drag-and-drop-enabled FlatList component for React Native",
  "keywords": [
    "react-native",
    "sortable",
    "draggable",
    "flatlist",
    "drag",
    "drop",
    "sort",
    "list"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/Kaosc/@kaosc/react-native-draggable-flatlist#readme",
  "bugs": {
    "url": "https://github.com/Kaosc/@kaosc/react-native-draggable-flatlist/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kaosc/@kaosc/react-native-draggable-flatlist.git"
  },
  "license": "MIT",
  "author": "Daniel Merrill",
  "type": "commonjs",
  "main": "lib/commonjs/index",
  "types": "lib/typescript/index.d.ts",
  "scripts": {
    "typecheck": "tsc --skipLibCheck --noEmit",
    "build": "bob build"
  },
  "dependencies": {
    "@babel/preset-typescript": "^7.17.12"
  },
  "devDependencies": {
    "@types/react": "^19.1.1",
    "@types/react-native": "^0.73.0",
    "babel-jest": "^29.7.0",
    "husky": "^4.2.0",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "prettier": "^3.0.0",
    "pretty-quick": "^4.0.0",
    "react": "^19.2.6",
    "react-native": "0.83.6",
    "react-native-builder-bob": "^0.20.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "react-native": ">=0.83.6",
    "react-native-gesture-handler": ">=2.30.0",
    "react-native-reanimated": ">=4.2.1"
  },
  "module": "lib/module/index",
  "react-native": "src/index.tsx",
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged"
    }
  },
  "jest": {
    "preset": "react-native",
    "setupFiles": [
      "./node_modules/react-native-gesture-handler/jestSetup.js",
      "./jest-setup.js"
    ],
    "transform": {
      "^.+\\.[t|j]sx?$": "babel-jest"
    },
    "transformIgnorePatterns": []
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "configFile": "./babel.config.js"
        }
      ],
      "module",
      "typescript"
    ]
  },
  "codegenConfig": {
    "libraries": [
      {
        "name": "@kaosc/@kaosc/react-native-draggable-flatlist",
        "type": "components",
        "jsSrcsDir": "src"
      }
    ]
  }
}
